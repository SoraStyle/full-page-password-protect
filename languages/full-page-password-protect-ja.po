msgid "Full Page Password Protect"
msgstr "Full Page Password Protect"

msgid "Protects the full page with the WordPress standard password form, not only the post content."
msgstr "WordPress標準のパスワード保護を拡張し、本文だけでなくページ全体を保護します。"

msgid "Full Page Password"
msgstr "Full Page Password"

msgid "Protection Settings"
msgstr "保護設定"

msgid "Enable plugin"
msgstr "プラグインを有効化"

msgid "Protected post types"
msgstr "保護対象の投稿タイプ"

msgid "Archive display mode"
msgstr "一覧表示モード"

msgid "Password message"
msgstr "パスワード説明文"

msgid "Enable full page password protection."
msgstr "ページ全体のパスワード保護を有効にします。"

msgid "Only public post types can be protected."
msgstr "public な投稿タイプのみ保護対象にできます。"

msgid "Exclude protected posts"
msgstr "保護投稿を除外"

msgid "Show title only"
msgstr "タイトルのみ表示"

msgid "Title only mode hides excerpts, content, and featured images in listings."
msgstr "タイトルのみ表示では、一覧上の抜粋、本文、アイキャッチ画像を非表示にします。"

msgid "Protected Page"
msgstr "保護されたページ"

msgid "Password protected content"
msgstr "パスワード保護コンテンツ"

msgid ""
"This page is password protected.\n"
"Please enter the password to view it."
msgstr ""
"このページはパスワードで保護されています。\n"
"閲覧するにはパスワードを入力してください。"

msgid "The password is incorrect. Please try again."
msgstr "パスワードが違います。もう一度入力してください。"
